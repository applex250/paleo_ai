{
  "name": "ai-ops-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx watch server/index.ts",
    "dev:all": "concurrently -n web,api -c cyan,green \"npm run dev\" \"npm run server\"",
    "build": "tsc && vite build",
    "start": "tsx server/index.ts",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.22.2",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^26.1.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "tsx": "^4.22.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
